# Application
APP_NAME=Покер-планирование
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/planning_poker

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://frontend.pocker-planning.orb.local,http://frontend.pocker-planning.orb.local

# Demo Data
SEED_DEMO_DATA=false
DEMO_USER_PASSWORD=DemoPass123!
